{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@capy-kit/core": ["packages/core/src/index.ts"],
      "@capy-kit/core/*": ["packages/core/src/*"]
    }
  },
  "include": [
    "packages/*/src",
    "packages/*/test",
    "scripts",
    "tsup.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["**/dist", "**/node_modules"]
}
